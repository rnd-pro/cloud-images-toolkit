{
  "name": "cloud-images-toolkit",
  "version": "1.2.0",
  "description": "CIT - Cloud Images Toolkit for web developers. Manage image collections with CDN sync, adaptive embed code, and interactive widget generation.",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'",
    "types": "tsc -p ts.hook.json",
    "start": "node ./src/node/serve.js",
    "test:node": "node --test --test-timeout 20000 test/unit/*.test.js test/integration/*.test.js",
    "test:e2e": "npx playwright test",
    "test": "npm run test:node && npm run test:e2e",
    "pub": "npm run types && npm test && npm publish"
  },
  "author": "team@rnd-pro.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rnd-pro/cloud-images-toolkit.git"
  },
  "homepage": "https://rnd-pro.com/cit/",
  "bugs": {
    "url": "https://github.com/rnd-pro/cloud-images-toolkit/issues"
  },
  "keywords": [
    "images",
    "adaptive images",
    "responsive images",
    "web images",
    "image optimization",
    "cit",
    "cdn",
    "image cdn",
    "cloudflare",
    "cloudinary",
    "imagekit",
    "bunny",
    "image-management",
    "media collection management",
    "git based collaboration",
    "immersive-media-spots",
    "interactive widgets",
    "hypermedia",
    "gallery",
    "panorama",
    "360",
    "video streaming",
    "jsda"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "types/",
    "cit-config_REFERENCE.json",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "cit": "./bin/cit.js",
    "cloud-images-toolkit": "./bin/cit.js"
  },
  "dependencies": {
    "@symbiotejs/symbiote": "^3.5.8",
    "esbuild": "^0.27.4",
    "image-size": "^2.0.2",
    "immersive-media-spots": "^1.3.4",
    "jsda-kit": "^1.3.9",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.30",
    "typescript": "^5.4.3"
  }
}
